  "reviews": [
    {
      "id": 1,
      "gameId": 1,
      "userId": 2,
      "username": "LauraB",
      "rating": 5,
      "comment": "God of War Ragnarök è un capolavoro assoluto. Kratos e Atreus mi hanno fatto emozionare come pochi giochi. Imperdibile.",
      "createdAt": "2025-01-10"
    },
    {
      "id": 2,
      "gameId": 1,
      "userId": 3,
      "username": "MarcoV",
      "rating": 4,
      "comment": "Storia e combattimenti stellari. Qualche sezione un po' lenta ma nel complesso eccellente.",
      "createdAt": "2025-01-15"
    },
    {
      "id": 3,
      "gameId": 1,
      "userId": 4,
      "username": "SofiaF",
      "rating": 5,
      "comment": "Il finale mi ha spezzato il cuore in mille pezzi. Capolavoro della narrativa videoludica.",
      "createdAt": "2025-01-20"
    },
    {
      "id": 4,
      "gameId": 4,
      "userId": 1,
      "username": "MarioR",
      "rating": 5,
      "comment": "Elden Ring è il gioco più soddisfacente che abbia mai completato. Ogni boss vinto sembra una conquista personale.",
      "createdAt": "2025-02-01"
    },
    {
      "id": 5,
      "gameId": 4,
      "userId": 2,
      "username": "LauraB",
      "rating": 5,
      "comment": "Open world senza mappa segnata e ci si sente sempre stupiti da ciò che si scopre. Un'opera d'arte.",
      "createdAt": "2025-02-05"
    },
    {
      "id": 6,
      "gameId": 13,
      "userId": 1,
